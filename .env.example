# Existing infra
TRAEFIK_DASHBOARD_HOST=traefik.local
MDNS_ADMIN_USERNAME=admin
MDNS_ADMIN_PASSWORD=
MDNS_TARGET_IP=192.168.1.10
MDNS_PUBLISH_IMAGE=mdns-admin:local

# App
APP_HOST=0.0.0.0
APP_PORT=8787
APP_BASE_URL=http://raspberrypi.local/niwaki/
APP_BASE_PATH=/niwaki

# Bootstrap / fallback access
BOOTSTRAP_HOST=raspberrypi.local
BOOTSTRAP_PORT=80

# Traefik / convenience access
TRAEFIK_ENABLED=true
TRAEFIK_HOST=deploy.local
TRAEFIK_FALLBACK_HOST=raspberrypi.local
TRAEFIK_ENTRYPOINT=web
TRAEFIK_DOCKER_NETWORK=proxy

# Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Optional. When set, it overrides ADMIN_PASSWORD.
# Format: pbkdf2_sha256$<iterations>$<salt>$<hex_digest>
ADMIN_PASSWORD_HASH=
SESSION_SECRET=change-this

# Stack registry
SETTINGS_DB_PATH=./data/niwaki.db
STACK_ROOT=/opt/rpi-infra

# Git
GIT_DEFAULT_BRANCH=main
GIT_PULL_FLAGS=--ff-only

# Logging / history
COMMAND_LOG_RETENTION_DAYS=30
COMMAND_OUTPUT_MAX_LINES=200
# Optional legacy JSONL import source. Existing history is imported into SETTINGS_DB_PATH on first boot.
AUDIT_LOG_PATH=./data/command-history.jsonl

# Docker
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_API_VERSION=v1.41

# mDNS feature
MDNS_ENABLED=true
MDNS_DEFAULT_DOMAIN=local
MDNS_MANAGED_LABEL=io.mdns-admin.managed
MDNS_ALIAS_LABEL=io.mdns-admin.alias
MDNS_TARGET_IP_LABEL=io.mdns-admin.target-ip
